---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";

const features = [
  {
    title: "GPT Integration",
    description: "Seamlessly connect with OpenAI's GPT models. Generate content, answer questions, and automate responses with state-of-the-art AI.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`,
  },
  {
    title: "Smart Chatbot",
    description: "Build intelligent chatbots that understand context and provide relevant responses. Perfect for customer support and lead qualification.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>`,
  },
  {
    title: "Content Generation",
    description: "Automate content creation with AI. Blog posts, product descriptions, social media content, and more — generated in seconds.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>`,
  },
  {
    title: "Context Awareness",
    description: "AI that understands your business context. Train on your data to provide accurate, relevant responses.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>`,
  },
  {
    title: "API & Webhooks",
    description: "Integrate AI capabilities into your existing workflows with REST API and webhooks.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>`,
  },
  {
    title: "Custom Training",
    description: "Fine-tune AI models on your specific data. Create personalized experiences for your users.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>`,
  },
];

const useCases = [
  {
    title: "Customer Support",
    description: "Automate support responses with AI that understands your products and policies.",
  },
  {
    title: "Content Creation",
    description: "Generate blog posts, emails, and marketing copy automatically.",
  },
  {
    title: "Lead Qualification",
    description: "Use AI to qualify leads and route them to the right team.",
  },
  {
    title: "Internal Search",
    description: "Build intelligent search that understands user intent.",
  },
];
---

<BaseLayout title="Laravel GPT - AI-Powered Laravel Applications">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-br from-purple-900 via-purple-800 to-indigo-900"></div>
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 left-10 w-72 h-72 bg-purple-400 rounded-full filter blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-indigo-400 rounded-full filter blur-3xl"></div>
    </div>
    
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          AI-Powered Laravel
        </div>

        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          Bring AI to Your <span class="text-transparent bg-clip-text bg-linear-to-r from-purple-300 to-indigo-300">Laravel App</span>
        </h1>

        <p class="text-xl md:text-2xl text-purple-100 mb-8 max-w-3xl mx-auto leading-relaxed">
          AI-powered Laravel application with GPT integration. Intelligent content generation, automated responses, and smart chatbot capabilities.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="#" size="lg" class="bg-white text-purple-900 hover:bg-purple-50">
            Start Building
          </Button>
          <Button href="#" size="lg" variant="outline" class="border-white text-white hover:bg-white/10">
            View Documentation
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <Section background="gray">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Powerful AI Features
        </h2>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          Everything you need to add intelligent AI capabilities to your Laravel application.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="bg-slate-800/50 rounded-2xl p-8 border border-slate-700 hover:border-purple-500 transition-all group">
            <div class="w-14 h-14 rounded-xl bg-linear-to-br from-purple-500 to-indigo-600 text-white flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
              <div set:html={feature.icon} />
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{feature.title}</h3>
            <p class="text-slate-400 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Use Cases Section -->
  <Section background="gray">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Use Cases
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Discover what you can build with Laravel GPT.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {useCases.map((useCase) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
            <h3 class="text-xl font-bold text-gray-900 mb-3">{useCase.title}</h3>
            <p class="text-gray-600 leading-relaxed">{useCase.description}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-br from-purple-900 to-indigo-800"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center text-white">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Start Building with AI
        </h2>
        <p class="text-xl text-purple-100 mb-8">
          Add intelligent AI capabilities to your Laravel application today.
        </p>
        <Button href="#" size="lg" class="bg-white text-purple-900 hover:bg-purple-50">
          Get Started Free
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
