---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';
import ImageReveal from '../components/react/ImageReveal';

import nativeImg from '@assets/photo-1551288049-bebda4e38f71.jpg';
import dashboardImg from '@assets/photo-1551288049-bebda4e38f71.jpg';
import headlessImg from '@assets/photo-1518770660439-4636190af475.jpg';
import pipelineImg from '@assets/photo-1522071820081-009f0129c71c.jpg';
import securityImg from '@assets/photo-1563013544-824ae1b704d3.jpg';

import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const pillars = [
  {
    name: 'Laravel-Native Design',
    subtitle: 'Built for Artisan',
    type: 'Core Architecture',
    description: 'Integrates seamlessly with Eloquent, Blade, and the Service Container. No hacky workarounds or external dependencies.',
    image: nativeImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
    features: [
      'Eloquent Model Traits',
      'Blade Directives',
      'Config-driven',
      'Artisan Commands'
    ]
  },
  {
    name: 'Dashboard & Analytics',
    subtitle: 'Real-time Visibility',
    type: 'Monitoring',
    description: 'A beautiful, integrated dashboard to track your SEO health, Lighthouse scores, and social preview statuses in real-time.',
    image: dashboardImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
    features: [
      'Live Score Monitoring',
      'History Tracking',
      'Trend Analysis',
      'Instant Alerts'
    ]
  },
  {
    name: 'Headless-Ready',
    subtitle: 'API First',
    type: 'Architecture',
    description: 'Decoupled architecture allows you to consume SEO data via clean JSON APIs, perfect for Next.js, Nuxt, or mobile apps.',
    image: headlessImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    features: [
      'REST API',
      'GraphQL Support',
      'JSON Responses',
      'Webhooks'
    ]
  },
  {
    name: 'Pipeline-Friendly',
    subtitle: 'CI/CD Integration',
    type: 'DevOps',
    description: 'Block bad deployments before they happen. Run SEO checks as part of your CI pipeline with zero configuration.',
    image: pipelineImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>`,
    features: [
      'GitHub Actions',
      'GitLab CI',
      'Bitbucket Pipelines',
      'Exit Code Control'
    ]
  },
  {
    name: 'Built for Security',
    subtitle: 'Enterprise Grade',
    type: 'Security',
    description: 'Zero external service dependencies for core functionality. Your data stays on your servers. GDPR and CCPA compliant by design.',
    image: securityImg,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    features: [
      'Self-hosted',
      'No Third-party Tracking',
      'Role-based Access',
      'Audit Logging'
    ]
  }
];

const standards = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    title: 'Performance',
    description: 'Optimized for sub-millisecond overhead',
    color: 'from-violet-500 to-violet-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
    title: 'Security',
    description: 'Regular security audits and updates',
    color: 'from-green-500 to-green-600'
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
    title: 'Reliability',
    description: '100% test coverage and static analysis',
    color: 'from-purple-500 to-purple-600'
  }
];
---

<BaseLayout title="Technical Foundations - LaravelSeo">
  <!-- Hero Section -->
  <section class="relative h-[60vh] min-h-[400px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image 
        src= {ctaBgImg}
        alt="Technical Infrastructure"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-linear-to-r from-violet-600 to-pink-600 text-white text-sm font-semibold rounded-full shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
          </svg>
          Technical Pillars
        </div>
        
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          Built on <span class="text-transparent bg-clip-text bg-linear-to-r from-violet-400 via-pink-400 to-violet-400">
            Solid Foundations
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
          Engineered for performance, security, and developer happiness.
        </p>
      </div>
    </div>
  </section>

  <!-- Facilities/Features Grid -->
  <Section background="gray">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Core <span class="gradient-text">Architecture</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Designed from the ground up to integrate perfectly with the Laravel ecosystem.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {pillars.map((pillar, index) => (
        <ImageReveal client:load delay={index * 0.1}>
          <Card hover class="overflow-hidden animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
            <!-- Image -->
            <div class="relative h-64 overflow-hidden">
              <Image 
                src={pillar.image}
                alt={pillar.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                width={800}
                height={400}
              />
              <div class="absolute inset-0 bg-linear-to-t from-gray-900/80 via-gray-900/40 to-transparent"></div>
              <div class="absolute top-4 right-4">
                <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center border border-white/30" set:html={pillar.icon}></div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
                <h3 class="text-2xl font-bold mb-1">{pillar.name}</h3>
                <div class="text-sm font-semibold text-violet-200 bg-violet-900/50 inline-block px-2 py-1 rounded">{pillar.subtitle}</div>
              </div>
            </div>

            <div class="p-6 space-y-5">
              <p class="text-gray-600 leading-relaxed">
                {pillar.description}
              </p>

              <!-- Features -->
              <div>
                <h4 class="text-sm font-semibold text-gray-700 uppercase mb-3 tracking-wide flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Highlights
                </h4>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
                  {pillar.features.map((feature) => (
                    <li class="flex items-start space-x-2.5 text-sm">
                      <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-gray-600">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </Card>
        </ImageReveal>
      ))}
    </div>
  </Section>

  <!-- Standards -->
  <Section background="gradient">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-white/80 backdrop-blur-sm text-violet-800 text-sm font-semibold rounded-full border border-violet-200">
        Quality Assurance
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Engineering <span class="gradient-text">Standards</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        We refuse to compromise on code quality or performance.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {standards.map((feature, index) => (
        <Card hover class="text-center animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
          <div class={`w-16 h-16 mx-auto mb-4 rounded-xl bg-linear-to-br from-violet-500 to-violet-600 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-lg`} set:html={feature.icon}></div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-32 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={ctaBgImg}
        alt="Technical Infrastructure"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-violet-900/95 to-pink-900/95"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Get Started Today
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Ready to Deploy?
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed">
          Start building with the most advanced SEO toolkit for Laravel.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href="https://app.laravelseo.com/login" size="lg" class="bg-linear-to-r! from-violet-600! to-pink-600! hover:from-violet-500! hover:to-pink-500! text-white! shadow-2xl! hover:shadow-violet-500/50!">
            Login
          </Button>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>
