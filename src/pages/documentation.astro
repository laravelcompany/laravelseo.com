---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import {
  Book,
  Code,
  Shield,
  Terminal,
  Database,
  Search,
  Zap,
  Globe,
  Clock,
} from "lucide-react";

const docCategories = [
  {
    title: "Getting Started",
    icon: Zap,
    description: "Everything you need to get up and running.",
    links: [
      { text: "Installation", href: "#" },
      { text: "Configuration", href: "#" },
      { text: "Architecture Overview", href: "#" },
      { text: "Upgrade Guide", href: "#" },
    ],
  },
  {
    title: "Core Concepts",
    icon: Book,
    description: "Deep dive into how LaravelSeo works.",
    links: [
      { text: "The SeoManager Facade", href: "#" },
      { text: "Metadata Generation", href: "#" },
      { text: "OpenGraph & Twitter Cards", href: "#" },
      { text: "Sitemap Generation", href: "#" },
    ],
  },
  {
    title: "Advanced Usage",
    icon: Code,
    description: "Push the limits of what's possible.",
    links: [
      { text: "Custom Drivers", href: "#" },
      { text: "Macroable Traits", href: "#" },
      { text: "Event Listeners", href: "#" },
      { text: "Performance Tuning", href: "#" },
    ],
  },
  {
    title: "Integrations",
    icon: Terminal,
    description: "Connect with your favorite tools.",
    links: [
      { text: "FilamentPHP", href: "#" },
      { text: "Statamic", href: "#" },
      { text: "Nova", href: "#" },
      { text: "Inertia.js", href: "#" },
    ],
  },
  {
    title: "Security",
    icon: Shield,
    description: "Keep your application secure.",
    links: [
      { text: "Security Policy", href: "#" },
      { text: "GDPR Compliance", href: "#" },
      { text: "Data Sanitization", href: "#" },
      { text: "Audit Logs", href: "#" },
    ],
  },
  {
    title: "API Reference",
    icon: Database,
    description: "Complete API documentation.",
    links: [
      { text: "Class Reference", href: "#" },
      { text: "Artisan Commands", href: "#" },
      { text: "Helper Functions", href: "#" },
      { text: "Configuration Options", href: "#" },
    ],
  },
];

const popularArticles = [
  {
    title: "Setting up dynamic meta tags for Eloquent models",
    category: "Core Concepts",
    readTime: "5 min read",
  },
  {
    title: "Generating an XML sitemap with 100k+ URLs",
    category: "Performance",
    readTime: "8 min read",
  },
  {
    title: "Integrating with Filament Admin Panel",
    category: "Integrations",
    readTime: "6 min read",
  },
  {
    title: "Handling multi-language SEO (i18n)",
    category: "Advanced Usage",
    readTime: "10 min read",
  },
];
---

<BaseLayout title="Documentation - LaravelSeo">
  <!-- Hero Section -->
  <section class="bg-gray-900 text-white py-20 relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Documentation</h1>
        <p class="text-xl text-gray-300 mb-8">
          Comprehensive guides and API reference to help you build SEO-optimized
          Laravel applications.
        </p>

        <!-- Search Bar -->
        <div class="relative max-w-2xl mx-auto">
          <div
            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
          >
            <Search className="h-5 w-5 text-gray-400" />
          </div>
          <input
            type="text"
            class="block w-full pl-12 pr-4 py-4 bg-gray-800 border border-gray-700 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
            placeholder="Search documentation (e.g. 'sitemap', 'opengraph', 'installation')..."
          />
          <div
            class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none"
          >
            <span class="text-gray-500 text-sm">Cmd+K</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Background Decor -->
    <div
      class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 opacity-20"
    >
      <div
        class="absolute top-[-10%] right-[-5%] w-96 h-96 bg-blue-600 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-[-10%] left-[-5%] w-96 h-96 bg-teal-600 rounded-full blur-3xl"
      >
      </div>
    </div>
  </section>

  <Section>
    <div class="container mx-auto py-12">
      <!-- Categories Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        {
          docCategories.map((category) => (
            <div class="bg-white rounded-xl shadow-md border border-gray-100 p-6 hover:shadow-lg transition-shadow duration-300">
              <div class="flex items-center mb-4">
                <div class="w-12 h-12 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 mr-4">
                  <category.icon className="w-6 h-6" />
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 text-lg">
                    {category.title}
                  </h3>
                  <p class="text-sm text-gray-500">{category.description}</p>
                </div>
              </div>

              <ul class="space-y-3">
                {category.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="flex items-center text-gray-600 hover:text-blue-600 transition-colors group"
                    >
                      <span class="w-1.5 h-1.5 bg-gray-300 rounded-full mr-2 group-hover:bg-blue-600 transition-colors" />
                      {link.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- Popular Articles & Help -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Popular Articles
          </h2>
          <div class="space-y-4">
            {
              popularArticles.map((article) => (
                <a
                  href="#"
                  class="block bg-white border border-gray-200 rounded-lg p-6 hover:border-blue-300 hover:shadow-md transition-all group"
                >
                  <div class="flex items-center justify-between">
                    <div>
                      <div class="text-sm text-blue-600 font-semibold mb-1">
                        {article.category}
                      </div>
                      <h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-700 transition-colors">
                        {article.title}
                      </h3>
                    </div>
                    <div class="flex items-center text-gray-400 text-sm">
                      <Clock className="w-4 h-4 mr-1" />
                      {article.readTime}
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="bg-slate-900 text-white rounded-2xl p-8 sticky top-8">
            <h3 class="text-xl font-bold mb-4">Need Help?</h3>
            <p class="text-gray-300 mb-6">
              Can't find what you're looking for? Our support team is here to
              help you build the best possible application.
            </p>

            <div class="space-y-4">
              <a
                href="/rfq"
                class="flex items-center justify-center px-4 py-3 bg-white text-gray-900 font-bold rounded-lg hover:bg-gray-100 transition-colors w-full"
              >
                Contact Support
              </a>
              <a
                href="https://github.com/laravelseo/discussions"
                target="_blank"
                class="flex items-center justify-center px-4 py-3 bg-gray-800 text-white font-bold rounded-lg border border-gray-700 hover:border-gray-600 transition-colors w-full"
              >
                GitHub Discussions
              </a>
            </div>

            <div class="mt-8 pt-8 border-t border-gray-800">
              <div class="flex items-center">
                <div class="flex -space-x-2 mr-4">
                  <div
                    class="w-8 h-8 rounded-full bg-gray-700 border-2 border-slate-900"
                  >
                  </div>
                  <div
                    class="w-8 h-8 rounded-full bg-gray-600 border-2 border-slate-900"
                  >
                  </div>
                  <div
                    class="w-8 h-8 rounded-full bg-gray-500 border-2 border-slate-900"
                  >
                  </div>
                </div>
                <div class="text-sm text-gray-400">
                  <span class="text-white font-bold">500+</span> developers joined
                  the community
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
