---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import { Check } from "lucide-react";
import SoftwareProducts from "../components/home/SoftwareProducts.astro";

const features = [
  "Track up to 10,000 domains",
  "Real-time SEO monitoring",
  "One-time payment",
  "Lifetime access",
  "Instant activation",
  "Premium support",
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Laravel SEO",
  image: "https://laravelseo.com/logo.svg",
  description:
    "Automated SEO suite for Laravel applications. Track, tune, and improve your SEO performance instantly.",
  brand: {
    "@type": "Brand",
    name: "Laravel SEO",
  },
  offers: {
    "@type": "Offer",
    url: "https://laravelseo.com/buy",
    priceCurrency: "GBP",
    price: "10.00",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2025-12-31",
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

<BaseLayout
  title="Buy Laravel SEO - Simple pricing"
  description="Get lifetime access to Laravel SEO for a single one-time payment. Track up to 10,000 domains."
>
  <Section
    background="gray"
    class="min-h-screen flex items-center justify-center"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6">
          Simple, Transparent <span
            class="text-transparent bg-clip-text bg-linear-to-r from-violet-400 to-pink-400"
            >Pricing</span
          >
        </h1>
        <p class="text-xl text-slate-400">
          Everything you need to optimize your Laravel applications. No monthly
          fees.
        </p>
      </div>

      <div class="max-w-md mx-auto relative group">
        <!-- Glow Effect -->
        <div
          class="absolute -inset-1 bg-linear-to-r from-violet-600 to-pink-600 rounded-2xl blur-sm opacity-75 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"
        >
        </div>

        <div
          class="relative bg-slate-900 ring-1 ring-slate-800 rounded-2xl p-8 shadow-2xl"
        >
          <div class="text-center mb-8">
            <span
              class="inline-block px-4 py-1.5 bg-violet-500/10 text-violet-300 text-sm font-semibold rounded-full border border-violet-500/20 mb-4"
            >
              Limited Time Offer
            </span>
            <div class="flex items-baseline justify-center gap-2">
              <span class="text-5xl font-bold text-white">£10</span>
              <span class="text-slate-400">/ one-time</span>
            </div>
            <p class="text-slate-400 mt-2">Pay once, use forever</p>
          </div>

          <div class="space-y-4 mb-8">
            {
              features.map((feature) => (
                <div class="flex items-center text-slate-300">
                  <Check className="w-5 h-5 text-green-400 mr-3 shrink-0" />
                  <span>{feature}</span>
                </div>
              ))
            }
          </div>

          <Button
            href="https://paypal.me/laravelseo"
            size="lg"
            class="w-full bg-linear-to-r! from-blue-600! to-blue-700! hover:from-blue-500! hover:to-blue-600! text-white! shadow-lg! justify-center"
            onclick="gtag('event', 'begin_checkout', {'currency': 'GBP', 'value': 10.00, 'items': [{'item_name': 'Laravel SEO', 'price': 10.00}]});"
          >
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M7.076 21.337l.794-4.839h3.69c4.279 0 7.646-2.003 8.356-6.42.339-2.126-.41-3.929-2.072-5.066-1.579-1.096-3.83-1.631-6.732-1.631H6.012C5.55 3.38 5.15 3.731 5.07 4.19L2.83 18.77c-.05.297.16.567.46.567h3.786z"
              ></path>
            </svg>
            Pay with PayPal
          </Button>

          <p class="text-xs text-slate-500 text-center mt-6">
            Secure payment via PayPal. 30-day money-back guarantee.
          </p>
        </div>
      </div>
    </div>
  </Section>
  <SoftwareProducts />
</BaseLayout>
