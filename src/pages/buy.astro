---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import { Check } from "lucide-react";
import SoftwareProducts from "../components/home/SoftwareProducts.astro";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Laravel SEO",
  image: "https://laravelseo.com/logo.svg",
  description:
    "Automated SEO suite for Laravel applications. Track, tune, and improve your SEO performance instantly.",
  brand: {
    "@type": "Brand",
    name: "Laravel SEO",
  },
  offers: {
    "@type": "Offer",
    url: "https://laravelseo.com/buy",
    priceCurrency: "GBP",
    price: "10.00",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2025-12-31",
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

<BaseLayout
  title="Buy Laravel SEO - Simple pricing"
  description="Get lifetime access to Laravel SEO for a single one-time payment. Track up to 10,000 domains."
>
  <Section
    background="gray"
    class="min-h-screen flex items-center justify-center"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
          <!-- Left Column: Pricing & Value -->
          <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">
            <div class="flex items-center gap-3 mb-8">
              <span class="text-3xl">💎</span>
              <h2 class="text-2xl font-bold m-0 text-white"> Product Details </h2>
            </div>
            <div class="space-y-6">
              <!-- Price -->
              <div class="bg-gradient-to-br from-violet-500/20 to-blue-500/10 rounded-2xl p-6 border border-violet-500/30">
                <div class="flex items-baseline gap-2">
                  <span class="text-5xl font-black text-white">£10</span>
                  <span class="text-white/60 text-lg">one-time</span>
                </div>
                <p class="text-white/60 text-sm mt-3"> Lifetime access • No monthly fees • No contracts </p>
              </div>

              <!-- What's Included -->
              <div class="space-y-4">
                <h3 class="text-lg font-semibold text-white"> What You Get: </h3>
                <div class="flex items-start gap-3">
                  <span class="text-2xl text-green-400 flex-shrink-0">✓</span>
                  <div>
                    <h4 class="text-white font-semibold"> Full Platform Access </h4>
                    <p class="text-sm text-white/60 mt-1"> Complete source code with full documentation. </p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-2xl text-green-400 flex-shrink-0">✓</span>
                  <div>
                    <h4 class="text-white font-semibold"> Track up to 10,000 domains </h4>
                    <p class="text-sm text-white/60 mt-1"> Monitor unlimited projects and keywords. </p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-2xl text-green-400 flex-shrink-0">✓</span>
                  <div>
                    <h4 class="text-white font-semibold"> Real-Time Analytics </h4>
                    <p class="text-sm text-white/60 mt-1"> Track every metric with detailed dashboards. </p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-2xl text-green-400 flex-shrink-0">✓</span>
                  <div>
                    <h4 class="text-white font-semibold"> Premium Support </h4>
                    <p class="text-sm text-white/60 mt-1"> Get help when you need it. </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column: Payment & Trust -->
          <div class="space-y-6">
            <!-- Payment Card -->
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">
              <div class="flex items-center gap-3 mb-8">
                <span class="text-3xl">💳</span>
                <h2 class="text-2xl font-bold m-0 text-white"> Get Started Today </h2>
              </div>
              <div class="space-y-6">
                <div class="bg-violet-500/10 border border-violet-500/30 rounded-xl p-4 text-center">
                  <p class="text-sm text-white/80 mb-2"> Instant Access </p>
                  <p class="text-lg font-bold text-white"> £10 one-time • Lifetime Use </p>
                  <p class="text-xs text-white/60 mt-2"> Start immediately after purchase </p>
                </div>

                <a
                  href="https://www.paypal.com/ncp/payment/PM95N2CF5YDW2"
                  class="block w-full py-4 px-6 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-500 hover:to-blue-600 text-white font-bold rounded-xl text-center transition-all shadow-lg"
                  onclick="gtag('event', 'begin_checkout', {'currency': 'GBP', 'value': 10.00, 'items': [{'item_name': 'Laravel SEO', 'price': 10.00}]});"
                >
                  <svg class="w-5 h-5 mr-2 inline" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M7.076 21.337l.794-4.839h3.69c4.279 0 7.646-2.003 8.356-6.42.339-2.126-.41-3.929-2.072-5.066-1.579-1.096-3.83-1.631-6.732-1.631H6.012C5.55 3.38 5.15 3.731 5.07 4.19L2.83 18.77c-.05.297.16.567.46.567h3.786z"></path>
                  </svg>
                  Pay with PayPal
                </a>

                <script type="module">
                  document.addEventListener("astro:page-load", () => {
                    if (typeof gtag == "undefined") return;
                    gtag("event", "view_item", {
                      currency: "GBP",
                      value: 10,
                      items: [
                        {
                          item_id: "laravelseo_license",
                          item_name: "Laravel SEO Lifetime License",
                          item_category: "Software",
                          item_variant: "One-time £10",
                          price: 10,
                          quantity: 1,
                        },
                      ],
                    });
                    gtag("event", "begin_checkout", {
                      currency: "GBP",
                      value: 10,
                      items: [
                        {
                          item_id: "laravelseo_license",
                          item_name: "Laravel SEO Lifetime License",
                          item_category: "Software",
                          item_variant: "One-time £10",
                          price: 10,
                          quantity: 1,
                        },
                      ],
                    });
                    document
                      .querySelectorAll('a[href*="paypal.com"]')
                      .forEach((e) => {
                        e.addEventListener("click", function () {
                          gtag("event", "add_to_cart", {
                            currency: "GBP",
                            value: 10,
                            items: [
                              {
                                item_id: "laravelseo_license",
                                item_name: "Laravel SEO Lifetime License",
                                item_category: "Software",
                                item_variant: "One-time £10",
                                price: 10,
                                quantity: 1,
                              },
                            ],
                          });
                          gtag("event", "click", {
                            event_category: "ecommerce",
                            event_label: "PayPal Purchase Button",
                            value: 10,
                          });
                        });
                      });
                  });
                </script>

                <p class="text-sm text-white/50 text-center px-4 leading-relaxed">
                  Secure PayPal checkout • No refunds on software licenses
                </p>

                <!-- Trust Badges -->
                <div class="flex items-center justify-center gap-3 pt-2">
                  <svg class="h-5 w-5 text-white/50" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"></path>
                  </svg>
                  <span class="text-xs text-white/60">SSL Encrypted</span>
                </div>
              </div>
            </div>

            <!-- Benefits Grid -->
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <div class="text-3xl mb-3">🚀</div>
                <h4 class="text-white font-semibold text-sm mb-2"> Deploy in Minutes </h4>
                <p class="text-xs text-white/60"> Easy setup + full docs </p>
              </div>
              <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <div class="text-3xl mb-3">📊</div>
                <h4 class="text-white font-semibold text-sm mb-2"> Real-Time Analytics </h4>
                <p class="text-xs text-white/60"> Track every metric </p>
              </div>
              <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <div class="text-3xl mb-3">🔒</div>
                <h4 class="text-white font-semibold text-sm mb-2"> 100% Control </h4>
                <p class="text-xs text-white/60"> Self-hosted data </p>
              </div>
              <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <div class="text-3xl mb-3">♾️</div>
                <h4 class="text-white font-semibold text-sm mb-2"> No Limits </h4>
                <p class="text-xs text-white/60"> Unlimited contacts </p>
              </div>
            </div>

            <!-- Security Badge -->
            <div class="flex items-center gap-4 p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="p-3 bg-green-500/10 rounded-full flex-shrink-0">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-bold m-0 text-sm"> Bank-Grade Security </h3>
                <p class="text-xs text-white/50 m-0"> 256-bit SSL encryption • Secure PayPal checkout </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>
  <SoftwareProducts />
</BaseLayout>
