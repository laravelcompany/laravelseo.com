---
import BaseLayout from "../../layouts/BaseLayout.astro";
import posts from "../../data/posts.json";

const ITEMS_PER_PAGE = 12;
const totalPosts = posts.length;
const totalPages = Math.ceil(totalPosts / ITEMS_PER_PAGE);

const currentPage = Number(Astro.url.searchParams.get("page")) || 1;
const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
const endIndex = startIndex + ITEMS_PER_PAGE;
const paginatedPosts = posts.slice(startIndex, endIndex);

function getPageUrl(page: number) {
  return page === 1 ? "/posts" : `/posts?page=${page}`;
}

function getPageNumbers(current: number, total: number): number[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  if (current <= 4) return [1, 2, 3, 4, 5, 6, 7];
  if (current >= total - 3) return [total - 6, total - 5, total - 4, total - 3, total - 2, total - 1, total];
  return [current - 3, current - 2, current - 1, current, current + 1, current + 2, current + 3];
}

const platformColors: Record<string, string> = {
  Facebook: "bg-blue-600",
  LinkedIn: "bg-blue-700",
  X: "bg-slate-800",
  Instagram: "bg-pink-600",
};

const sentimentColors: Record<string, string> = {
  Positive: "text-green-400",
  Negative: "text-red-400",
  Neutral: "text-yellow-400",
};
---

<BaseLayout
  title="Climate Posts - Social Media Analytics"
  description="Browse climate-related social media posts with engagement metrics and sentiment analysis"
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight">Climate Posts</h1>
      <p class="text-lg text-slate-400">
        Browse {totalPosts.toLocaleString()} climate-related social media posts
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        paginatedPosts.map((post) => (
          <a
            href={`/posts/${post.post_id}`}
            class="group flex flex-col rounded-xl border border-slate-800 bg-slate-900/50 p-5 transition-all hover:border-slate-700 hover:bg-slate-900"
          >
            <div class="mb-3 flex items-center justify-between">
              <span
                class={`rounded-full px-2.5 py-1 text-xs font-medium text-white ${platformColors[post.platform] || "bg-slate-700"}`}
              >
                {post.platform}
              </span>
              <span class={`text-sm font-medium ${sentimentColors[post.post_sentiment] || "text-slate-400"}`}>
                {post.post_sentiment}
              </span>
            </div>

            <p class="mb-3 flex-1 text-sm leading-relaxed text-slate-300 line-clamp-3">
              {post.post_text}
            </p>

            <div class="space-y-2 border-t border-slate-800 pt-3 text-xs text-slate-500">
              <div class="flex items-center justify-between">
                <span class="flex items-center gap-1">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                  {Number(post.engagement_likes).toLocaleString()}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                  </svg>
                  {Number(post.engagement_shares).toLocaleString()}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                  {Number(post.engagement_comments).toLocaleString()}
                </span>
              </div>
              <div class="flex items-center justify-between">
                <span>{post.username}</span>
                <span>{post.post_date}</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <nav class="mt-12 flex items-center justify-center gap-2" aria-label="Pagination">
          {
            currentPage > 1 && (
              <a
                href={getPageUrl(currentPage - 1)}
                class="rounded-lg border border-slate-700 bg-slate-900 px-4 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800"
              >
                Previous
              </a>
            )
          }

          <div class="flex items-center gap-1">
            {getPageNumbers(currentPage, totalPages).map((pageNum) => {
              const isActive = pageNum === currentPage;
              return (
                <a
                  href={getPageUrl(pageNum)}
                  class={`min-w-[40px] rounded-lg px-3 py-2 text-sm font-medium transition-colors ${isActive ? "bg-blue-600 text-white" : "border border-slate-700 bg-slate-900 text-slate-300 hover:bg-slate-800"}`}
                >
                  {pageNum}
                </a>
              );
            })}
          </div>

          {
            currentPage < totalPages && (
              <a
                href={getPageUrl(currentPage + 1)}
                class="rounded-lg border border-slate-700 bg-slate-900 px-4 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-800"
              >
                Next
              </a>
            )
          }
        </nav>
      )
    }
  </section>
</BaseLayout>
