---
interface Props {
  class?: string;
  background?: "white" | "gray" | "dark" | "gradient";
  id?: string;
}

const { class: className = "", background = "white", id } = Astro.props;

const bgStyles = {
  white: "bg-slate-950",
  gray: "bg-slate-900",
  dark: "bg-slate-900",
  gradient: "bg-linear-to-br from-violet-900/20 via-slate-900 to-pink-900/20",
};

const classes = `py-16 lg:py-24 ${bgStyles[background]} ${className}`;
---

<section class={classes} id={id}>
  <div class="container mx-auto">
    <slot />
  </div>
</section>
