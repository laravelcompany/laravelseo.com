---
import { NAVIGATION, SOCIAL_LINKS, SITE } from "@config/site";
import { Package, Linkedin, Twitter, Facebook } from "lucide-react";
---

<footer class="bg-slate-900 text-slate-300">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <!-- Company Info -->
      <div class="lg:col-span-1 space-y-6">
        <a href="/" class="flex items-center space-x-3 group">
          <img src="/logo.svg" alt="Laravel Seo Logo" class="w-12 h-12" />
          <span class="text-2xl font-bold text-white"> Laravel Seo </span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          {SITE.description}
        </p>
        <div class="flex space-x-4">
          <a
            href={SOCIAL_LINKS.linkedin}
            class="w-10 h-10 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:bg-violet-600 hover:text-white transition-all duration-300 transform hover:scale-110"
            aria-label="LinkedIn"
          >
            <Linkedin className="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-wider text-white mb-6"
        >
          Quick Links
        </h3>
        <ul class="space-y-3">
          {
            NAVIGATION.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
                >
                  <span class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2" />
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-wider text-white mb-6"
        >
          Features
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/capabilities"
              class="text-sm text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              Real-Time Lighthouse
            </a>
          </li>
          <li>
            <a
              href="/capabilities"
              class="text-sm text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              Automatic Meta Tags
            </a>
          </li>
          <li>
            <a
              href="/capabilities"
              class="text-sm text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              OpenGraph & Social
            </a>
          </li>
          <li>
            <a
              href="/capabilities"
              class="text-sm text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              Schema Generation
            </a>
          </li>
        </ul>
      </div>

      <!-- Get Started -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-wider text-white mb-6"
        >
          Get Started
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="/privacy"
              class="text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              Privacy Policy
            </a>
          </li>
          <li>
            <a
              href="/terms"
              class="text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              Terms of Service
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="text-slate-400 hover:text-violet-400 transition-colors inline-flex items-center group"
            >
              <span
                class="w-0 group-hover:w-2 h-0.5 bg-violet-400 transition-all mr-0 group-hover:mr-2"
              ></span>
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
