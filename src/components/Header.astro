---
import { NAVIGATION } from "@config/site";
import { Package } from "lucide-react";
import MobileMenu from "@components/react/MobileMenu";

const { currentPathname } = Astro.props;
const isActiveLink = (href: string): boolean => {
  return href === currentPathname;
};
---

<header
  class="sticky top-0 z-50 w-full border-b border-slate-800 bg-slate-900/95 backdrop-blur-md shadow-lg"
>
  <nav
    class="container mx-auto flex h-20 items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <!-- Logo -->
    <div class="flex items-center">
      <a href="/" class="flex items-center space-x-3 group">
        <img
          src="/logo.svg"
          alt="Laravel SEO Logo"
          width="40"
          height="40"
          class="w-10 h-10 group-hover:scale-110 transition-transform"
        />
        <span
          class="text-2xl font-bold bg-linear-to-r from-violet-400 to-pink-400 bg-clip-text text-transparent"
        >
          <h1>Laravel SEO</h1>
        </span>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {
        NAVIGATION.map((item) => {
          const isActive = isActiveLink(item.href);
          return (
            <a
              href={item.href}
              class={`px-4 py-2 text-sm font-medium text-slate-300 hover:text-violet-400 hover:bg-slate-800 rounded-lg transition-all relative group ${isActive ? "nav-active" : ""}`}
            >
              {item.name}
            </a>
          );
        })
      }
    </div>

    <!-- CTA Button -->
    <div class="hidden lg:flex lg:items-center lg:space-x-4">
      <a
        href="https://app.laravelseo.com/login"
        class="inline-flex items-center px-6 py-2.5 text-sm font-semibold text-white bg-linear-to-r from-violet-600 to-pink-600 hover:from-violet-500 hover:to-pink-500 rounded-lg shadow-lg hover:shadow-violet-500/50 transition-all"
      >
        Login
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <MobileMenu client:idle />
  </nav>
</header>
