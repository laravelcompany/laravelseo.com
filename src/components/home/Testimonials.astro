---
const testimonials = [
  { 
    quote: "LaravelSeo transformed how we handle SEO for our SaaS. The automated Lighthouse reports are a game changer.",
    name: "Sarah Johnson",
    initials: "SJ",
    role: "CTO at SaaSify"
  },
  { 
    quote: "Finally, an SEO tool that speaks 'Laravel'. The integration is seamless and the insights are actually actionable.",
    name: "Mark Taylor",
    initials: "MT",
    role: "Senior Dev at AgencyX"
  },
  { 
    quote: "The keyword research and SERP tracking tools alone are worth the subscription. Highly recommended for any Laravel project.",
    name: "Elena Rodriguez",
    initials: "ER",
    role: "Founder of ShopLogic"
  }
];
---

<section id="testimonials" class="bg-slate-800 border-t border-slate-700 py-20" aria-labelledby="testimonials-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
        Success Stories
      </div>
      <h2 id="testimonials-heading" class="text-3xl md:text-4xl font-bold text-white mb-4">
        Trusted by Laravel Developers
      </h2>
      <p class="text-slate-300 text-lg">
        Join hundreds of developers who have optimized their Laravel apps with our suite.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
      {testimonials.map(testimonial => (
        <div class="p-6 bg-slate-900/50 rounded-xl border border-slate-700/50 hover:border-violet-500/50 hover:shadow-lg hover:shadow-violet-500/10 transition-all h-full">
          <div class="mb-4 text-violet-400">
            <span class="text-4xl">"</span>
          </div>
          <p class="text-slate-300 italic mb-6 flex-grow-1">{testimonial.quote}</p>
          <div class="flex items-center mt-auto pt-4 border-t border-slate-700">
            <div class="w-10 h-10 bg-violet-600 rounded-full flex items-center justify-center text-white font-bold mr-3">
              {testimonial.initials}
            </div>
            <div>
              <h6 class="text-white font-bold mb-0">{testimonial.name}</h6>
              <small class="text-slate-400">{testimonial.role}</small>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>