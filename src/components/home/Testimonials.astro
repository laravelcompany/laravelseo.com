---
import TestimonialCard from "../ui/TestimonialCard.astro";

import testimonial1Img from "@assets/photo-1494790108377-be9c29b29330.jpg";
import testimonial2Img from "@assets/photo-1507003211169-0a1dd7228f2d.jpg";
import testimonial3Img from "@assets/photo-1438761681033-6461ffad8d80.jpg";

const testimonials = [
  {
    quote:
      "LaravelSeo transformed our core web vitals. Their automated monitoring solution improved our LCP by 40% and cut server response times significantly. The real-time visibility they provide is game-changing.",
    name: "Sarah Mitchell",
    role: "VP of Engineering, TechCorp",
    image: testimonial1Img,
    ringColor: "ring-violet-200",
  },
  {
    quote:
      "The auditing capabilities at LaravelSeo are exceptional. They've helped us scale our SaaS platform while maintaining perfect SEO scores. Their team's deep knowledge of the Laravel ecosystem gives us complete confidence.",
    name: "Robert Johnson",
    role: "CTO, Global SaaS Inc.",
    image: testimonial2Img,
    ringColor: "ring-pink-200",
  },
  {
    quote:
      "Outstanding performance partner. Their custom driver development and query optimization have improved our crawling efficiency by 300%. The dashboard gives us complete visibility into every meta tag.",
    name: "Emily Williams",
    role: "Lead Developer, RetailMax",
    image: testimonial3Img,
    ringColor: "ring-violet-200",
  },
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div
        class="inline-block px-4 py-2 mb-4 bg-pink-100 text-pink-800 text-sm font-semibold rounded-full"
      >
        Client Success Stories
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Trusted by <span
          class="text-transparent bg-clip-text bg-linear-to-r from-violet-600 to-pink-600"
          >Industry Leaders</span
        >
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        See how we've helped companies transform their supply chain operations
        and achieve remarkable results.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <TestimonialCard testimonial={testimonial} variant="home" />
        ))
      }
    </div>
  </div>
</section>
