---
const faqs = [
  { 
    question: "How does LaravelSeo integrate with my existing app?", 
    answer: "You can integrate it in seconds using our dedicated Laravel package. It provides native Blade directives and automated hooks for your models." 
  },
  { 
    question: "Do I need deep SEO knowledge to use it?", 
    answer: "Not at all. We translate complex Lighthouse data and SEO metrics into actionable tasks that any developer can implement." 
  },
  { 
    question: "Can I use it for multiple client sites?", 
    answer: "Yes! Our Agency plans are designed specifically for teams managing multiple Laravel installations from a single dashboard." 
  },
  { 
    question: "Is it compatible with Laravel 11/12?", 
    answer: "Absolutely. We stay at the cutting edge of the Laravel ecosystem, ensuring full compatibility with the latest versions." 
  }
];
---

<section id="faq" class="bg-slate-900 border-t border-b border-slate-700 py-20" aria-labelledby="faq-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
        FAQ
      </div>
      <h2 id="faq-heading" class="text-3xl md:text-4xl font-bold text-white mb-4">
        Frequently asked questions
      </h2>
    </div>

    <div class="max-w-3xl mx-auto mt-12 space-y-4">
      {faqs.map((faq, index) => (
        <div class="bg-slate-800/50 rounded-xl border border-slate-700/50 overflow-hidden">
          <button 
            class="w-full flex items-center justify-between p-4 text-left hover:bg-slate-800 transition-colors"
            aria-expanded={index === 0 ? "true" : "false"}
          >
            <h5 class="text-white font-semibold flex items-center">
              <span class="text-violet-400 mr-3">?</span>
              {faq.question}
            </h5>
            <svg class="w-5 h-5 text-slate-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="px-4 pb-4">
            <p class="text-slate-400 pl-8">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>