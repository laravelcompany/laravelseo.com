---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>`,
    title: "Reports",
    description: "Get detailed SEO reports for your webpages, and get tips on how to improve them."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
    title: "Projects",
    description: "Manage your reports more efficiently with the automatically generated projects."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: "Tools",
    description: "Expand your toolbox with our diverse web tools and utilities."
  }
];

const projects = [
  { domain: "example.com", status: "Good", time: "8 seconds ago", color: "green" },
  { domain: "example.net", status: "Decent", time: "52 minutes ago", color: "yellow" },
  { domain: "example.org", status: "Bad", time: "18 hours ago", color: "red" },
  { domain: "example.edu", status: "Good", time: "4 days ago", color: "green" },
  { domain: "example.uk", status: "Decent", time: "1 week ago", color: "yellow" }
];
---

<section class="bg-slate-900 py-16 md:py-28" aria-labelledby="complete-solution-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left Column - Features -->
      <div>
        <h2 id="complete-solution-heading" class="text-2xl md:text-3xl font-bold text-white mb-4">
          Complete solution
        </h2>
        <p class="text-slate-300 text-lg mb-8">
          Comprehensive platform to easily manage your SEO reports, projects and tools.
        </p>

        <div class="space-y-6">
          {features.map(feature => (
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-violet-600/20 rounded-xl flex items-center justify-center flex-shrink-0 text-violet-400">
                <Fragment set:html={feature.icon} />
              </div>
              <div>
                <h5 class="text-white font-semibold mb-1">{feature.title}</h5>
                <p class="text-slate-400 text-sm">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column - Projects List -->
      <div class="mt-8 lg:mt-0">
        <div class="bg-slate-800/50 rounded-2xl p-6 shadow-xl border border-slate-700/50">
          <div class="space-y-3">
            {projects.map(project => (
              <div class="flex items-center justify-between p-3 bg-slate-900/50 rounded-xl">
                <div class="flex items-center gap-3">
                  <div class={`w-3 h-3 rounded-full ${
                    project.color === 'green' ? 'bg-green-500' : 
                    project.color === 'yellow' ? 'bg-yellow-500' : 'bg-red-500'
                  }`}></div>
                  <div>
                    <div class="text-white font-medium">{project.domain}</div>
                    <div class="text-slate-500 text-xs">{project.time}</div>
                  </div>
                </div>
                <span class={`px-3 py-1 rounded-full text-xs font-medium ${
                  project.color === 'green' ? 'bg-green-500/20 text-green-400' : 
                  project.color === 'yellow' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-red-500/20 text-red-400'
                }`}>
                  {project.status}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>