---
import { Image } from "astro:assets";

import discoveryImg from "@assets/photo-1454165804606-c3d57bc86b40.jpg";
import implementationImg from "@assets/photo-1522071820081-009f0129c71c.jpg";
import optimizationImg from "@assets/photo-1551288049-bebda4e38f71.jpg";
import supportGrowthImg from "@assets/photo-1552664730-d307ca884978.jpg";

interface Step {
  number: number;
  title: string;
  description: string;
  image: ImageMetadata;
  alt: string;
  hoverBorder: string;
  gradient: string;
  textColor: string;
}

const steps = [
  {
    number: 1,
    title: "Discovery & Planning",
    description:
      "We analyze your current operations, identify pain points, and design a customized solution that aligns with your business goals.",
    image: discoveryImg,
    alt: "Business planning and strategy",
    hoverBorder: "hover:border-violet-500",
    gradient: "from-violet-600/90",
    textColor: "text-violet-600",
  },
  {
    number: 2,
    title: "Implementation",
    description:
      "Our expert team sets up your infrastructure, integrates systems, and ensures seamless onboarding with minimal disruption.",
    image: implementationImg,
    alt: "Team collaboration and implementation",
    hoverBorder: "hover:border-pink-500",
    gradient: "from-pink-600/90",
    textColor: "text-pink-700",
  },
  {
    number: 3,
    title: "Optimization",
    description:
      "Continuous monitoring and data-driven improvements ensure your operations become more efficient and cost-effective over time.",
    image: optimizationImg,
    alt: "Data analytics and optimization",
    hoverBorder: "hover:border-violet-500",
    gradient: "from-violet-600/90",
    textColor: "text-violet-600",
  },
  {
    number: 4,
    title: "Support & Growth",
    description:
      "Dedicated account management and 24/7 support help you scale operations and adapt to changing market demands.",
    image: supportGrowthImg,
    alt: "Customer support and growth",
    hoverBorder: "hover:border-pink-500",
    gradient: "from-pink-600/90",
    textColor: "text-pink-700",
  },
];

const arrowPath = "M9 5l7 7-7 7";
---

<section class="py-24 bg-slate-950">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div
        class="inline-block px-4 py-2 mb-4 bg-pink-500/10 text-pink-400 text-sm font-semibold rounded-full border border-pink-500/20"
      >
        Simple Integration
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6">
        How It <span
          class="text-transparent bg-clip-text bg-linear-to-r from-violet-400 to-pink-400"
          >Works</span
        >
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
        Straightforward setup, zero friction. Get running in minutes.
      </p>
    </div>

    <div class="relative">
      <!-- Connection Line (hidden on mobile) -->
      <div
        class="hidden lg:block absolute top-24 left-0 right-0 h-0.5 bg-linear-to-r from-violet-500/30 via-pink-500/30 to-violet-500/30"
      >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <div class="relative h-full">
          <div
            class="bg-slate-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-violet-500/20 transition-all border-2 border-slate-700 hover:border-violet-500 relative z-10 flex flex-col h-full group"
          >
            <div
              class="relative h-48 overflow-hidden bg-slate-900 flex items-center justify-center"
            >
              <!-- Placeholder for image -->
              <div class="text-6xl">📦</div>
              <div
                class="absolute top-4 right-4 w-12 h-12 rounded-full bg-violet-600 flex items-center justify-center text-white font-bold text-xl shadow-lg"
              >
                1
              </div>
            </div>
            <div class="p-8 flex flex-col flex-1">
              <h3 class="text-xl font-bold text-slate-100 mb-3">
                Install the package
              </h3>
              <p class="text-slate-400 leading-relaxed flex-1">
                Install the package with Composer. Straightforward setup, zero
                friction.
              </p>
            </div>
          </div>
        </div>

        <div class="relative h-full">
          <div
            class="bg-slate-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-pink-500/20 transition-all border-2 border-slate-700 hover:border-pink-500 relative z-10 flex flex-col h-full group"
          >
            <div
              class="relative h-48 overflow-hidden bg-slate-900 flex items-center justify-center"
            >
              <!-- Placeholder for image -->
              <div class="text-6xl">⚙️</div>
              <div
                class="absolute top-4 right-4 w-12 h-12 rounded-full bg-pink-600 flex items-center justify-center text-white font-bold text-xl shadow-lg"
              >
                2
              </div>
            </div>
            <div class="p-8 flex flex-col flex-1">
              <h3 class="text-xl font-bold text-slate-100 mb-3">
                Configure your rules
              </h3>
              <p class="text-slate-400 leading-relaxed flex-1">
                Use the UI or config files — whichever suits your workflow.
              </p>
            </div>
          </div>
        </div>

        <div class="relative h-full">
          <div
            class="bg-slate-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-violet-500/20 transition-all border-2 border-slate-700 hover:border-violet-500 relative z-10 flex flex-col h-full group"
          >
            <div
              class="relative h-48 overflow-hidden bg-slate-900 flex items-center justify-center"
            >
              <!-- Placeholder for image -->
              <div class="text-6xl">📈</div>
              <div
                class="absolute top-4 right-4 w-12 h-12 rounded-full bg-violet-600 flex items-center justify-center text-white font-bold text-xl shadow-lg"
              >
                3
              </div>
            </div>
            <div class="p-8 flex flex-col flex-1">
              <h3 class="text-xl font-bold text-slate-100 mb-3">
                Monitor SEO in real time
              </h3>
              <p class="text-slate-400 leading-relaxed flex-1">
                Every edit triggers a fresh Lighthouse audit. You see the impact
                instantly.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
