---

---

<section class="py-20 bg-slate-900/50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <h2
      class="text-3xl md:text-4xl font-bold text-center mb-20 text-white animate-fadeInUp"
    >
      Our <span class="gradient-text">Software Products</span>
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Laravel Mail Card -->
      <div class="animate-fadeInUp delay-100">
        <div class="group cursor-pointer">
          <div
            class="relative mb-8 h-80 bg-linear-to-br from-violet-600 to-violet-800 rounded-2xl overflow-hidden flex items-center justify-center shadow-lg hover:shadow-2xl hover:shadow-violet-500/20 transition-all duration-300 transform hover:scale-105"
          >
            <!-- Replaced Image with Icon/Placeholder as assets don't exist yet -->
            <div class="text-white text-center">
              <svg
                class="w-24 h-24 mx-auto mb-4 opacity-80"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              <span class="text-2xl font-bold">Laravel Mail</span>
            </div>
          </div>
          <h3
            class="text-3xl font-bold mb-4 text-white group-hover:text-violet-400 transition-colors"
          >
            Laravel Mail
          </h3>
          <p class="text-slate-400 mb-6 leading-relaxed text-lg">
            Advanced email marketing and automation platform. Send campaigns,
            manage subscribers, and track performance with powerful analytics.
          </p>
          <a
            href="/software/laravel-mail"
            class="inline-flex items-center gap-2 text-violet-400 hover:text-violet-300 font-semibold transition-colors group/link"
          >
            Learn more
            <span class="group-hover/link:translate-x-1 transition-transform"
              >→</span
            >
          </a>
        </div>
      </div>

      <!-- Laravel SEO Card -->
      <div class="animate-fadeInUp delay-200">
        <div class="group cursor-pointer">
          <div
            class="relative mb-8 h-80 bg-linear-to-br from-pink-600 to-pink-800 rounded-2xl overflow-hidden flex items-center justify-center shadow-lg hover:shadow-2xl hover:shadow-pink-500/20 transition-all duration-300 transform hover:scale-105"
          >
            <!-- Replaced with Icon -->
            <div class="text-white text-center">
              <svg
                class="w-24 h-24 mx-auto mb-4 opacity-80"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <span class="text-2xl font-bold">Laravel SEO</span>
            </div>
          </div>
          <h3
            class="text-3xl font-bold mb-4 text-white group-hover:text-pink-400 transition-colors"
          >
            Laravel SEO
          </h3>
          <p class="text-slate-400 mb-6 leading-relaxed text-lg">
            Comprehensive SEO toolkit for Laravel applications. Optimize meta
            tags, sitemaps, schema markup, and improve search rankings
            effortlessly.
          </p>
          <a
            href="/software/laravel-seo"
            class="inline-flex items-center gap-2 text-pink-400 hover:text-pink-300 font-semibold transition-colors group/link"
          >
            Learn more
            <span class="group-hover/link:translate-x-1 transition-transform"
              >→</span
            >
          </a>
        </div>
      </div>

      <!-- Laravel GPT Card -->
      <div class="animate-fadeInUp delay-300">
        <div class="group cursor-pointer">
          <div
            class="relative mb-8 h-80 bg-linear-to-br from-purple-600 to-purple-800 rounded-2xl overflow-hidden flex items-center justify-center shadow-lg hover:shadow-2xl hover:shadow-purple-500/20 transition-all duration-300 transform hover:scale-105"
          >
            <!-- Icon -->
            <div class="text-white text-center">
              <svg
                class="w-24 h-24 mx-auto mb-4 opacity-80"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              <span class="text-2xl font-bold">Laravel GPT</span>
            </div>
          </div>
          <h3
            class="text-3xl font-bold mb-4 text-white group-hover:text-purple-400 transition-colors"
          >
            Laravel GPT
          </h3>
          <p class="text-slate-400 mb-6 leading-relaxed text-lg">
            AI-powered Laravel application with GPT integration. Intelligent
            content generation, automated responses, and smart chatbot
            capabilities.
          </p>
          <a
            href="/software/laravel-gpt"
            class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-semibold transition-colors group/link"
          >
            Learn more
            <span class="group-hover/link:translate-x-1 transition-transform"
              >→</span
            >
          </a>
        </div>
      </div>

      <!-- Laravel UI Card -->
      <div class="animate-fadeInUp delay-400">
        <div class="group cursor-pointer">
          <div
            class="relative mb-8 h-80 bg-linear-to-br from-blue-600 to-blue-800 rounded-2xl overflow-hidden flex items-center justify-center shadow-lg hover:shadow-2xl hover:shadow-blue-500/20 transition-all duration-300 transform hover:scale-105"
          >
            <!-- Icon -->
            <div class="text-white text-center">
              <svg
                class="w-24 h-24 mx-auto mb-4 opacity-80"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
                ></path>
              </svg>
              <span class="text-2xl font-bold">Laravel UI</span>
            </div>
          </div>
          <h3
            class="text-3xl font-bold mb-4 text-white group-hover:text-blue-400 transition-colors"
          >
            Laravel UI
          </h3>
          <p class="text-slate-400 mb-6 leading-relaxed text-lg">
            Premium UI components designed for easy use with Laravel.
            High-quality Marketing and Application UI blocks built for
            conversion-driven applications.
          </p>
          <a
            href="/software/laravel-ui"
            class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold transition-colors group/link"
          >
            Learn more
            <span class="group-hover/link:translate-x-1 transition-transform"
              >→</span
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
