---
const facilities = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Global Edge Nodes",
    description: "Distributed monitoring across 25+ global regions for accurate local SEO data."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "ISO 27001 Certified",
    description: "Enterprise-grade security and compliance for your mission-critical Laravel apps."
  }
];
---

<section id="facilities" class="bg-slate-800 py-20" aria-labelledby="facilities-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
        Infrastructure & Compliance
      </div>
      <h2 id="facilities-heading" class="text-3xl md:text-4xl font-bold text-white mb-4">
        Global Monitoring Facilities
      </h2>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">
        Our infrastructure is built for speed, security, and global reach. We monitor your application from over 25 nodes worldwide.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
      {facilities.map(facility => (
        <div class="p-6 bg-slate-900/50 rounded-xl border border-slate-700/50 hover:border-violet-500/50 hover:shadow-lg hover:shadow-violet-500/10 transition-all">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 bg-violet-600/20 rounded-full flex items-center justify-center flex-shrink-0 text-violet-400">
              <Fragment set:html={facility.icon} />
            </div>
            <div>
              <h4 class="text-white font-bold mb-2">{facility.title}</h4>
              <p class="text-slate-400 mb-0">{facility.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>