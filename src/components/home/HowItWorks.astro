---
const steps = [
  { number: 1, title: "Install the package", description: "Install the package with Composer. Straightforward setup, zero friction." },
  { number: 2, title: "Configure your rules", description: "Use the UI or config files — whichever suits your workflow." },
  { number: 3, title: "Monitor SEO in real time", description: "Every edit triggers a fresh Lighthouse audit. You see the impact instantly." }
];
---

<section id="how-it-works" class="bg-slate-800 py-20" aria-labelledby="how-it-works-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
        Simple Integration
      </div>
      <h2 id="how-it-works-heading" class="text-3xl md:text-4xl font-bold text-white mb-4">
        How It Works
      </h2>
      <p class="text-slate-300 text-lg">
        Straightforward setup, zero friction. Get running in minutes.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
      {steps.map((step, index) => (
        <div class="text-center px-4">
          <div class="w-16 h-16 bg-violet-600/20 rounded-full flex items-center justify-center mx-auto mb-6 text-2xl font-bold text-violet-400">
            {step.number}
          </div>
          <h4 class="text-white font-bold mb-3">{step.title}</h4>
          <p class="text-slate-400">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>