---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import heroBgImg from "@assets/photo-1586528116311-ad8dd3c8310d.jpg";
---

<section
  class="relative h-screen min-h-[600px] flex items-center overflow-hidden"
>
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <Image
      src={heroBgImg}
      alt="Laravel SEO Dashboard"
      class="w-full h-full object-cover"
      width={2070}
      height={1380}
      decoding="async"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl">
      <div
        class="inline-flex items-center px-4 py-2 mb-6 bg-linear-to-r from-violet-600 to-pink-600 text-white text-sm font-semibold rounded-full shadow-lg"
      >
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path
            fill-rule="evenodd"
            d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
            clip-rule="evenodd"></path>
        </svg>
        Fully Automated SEO Suite
      </div>

      <h1
        class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight"
      >
        Supercharge Your Laravel SEO With Real-Time
        <span
          class="block text-transparent bg-clip-text bg-linear-to-r from-violet-400 via-pink-400 to-violet-400 mt-2"
        >
          Lighthouse Monitoring
        </span>
      </h1>

      <p
        class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl leading-relaxed"
      >
        Take control of your site’s search visibility with a fully automated
        optimisation suite built specifically for Laravel. Track, tune, and
        improve your SEO performance instantly — no guesswork, no external
        dashboards.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <Button
          href="/rfq"
          size="lg"
          class="bg-violet-600! hover:bg-violet-700! text-white! shadow-2xl!"
        >
          Request a Quote
        </Button>
        <Button
          href="/documentation"
          size="lg"
          variant="outline"
          class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!"
        >
          Documentation
        </Button>
      </div>

      <!-- Quick Stats removed as per briefing focus, or kept generic? Briefing didn't mention stats. -->
      <!-- Keeping structure but commenting out if not needed, or replacing with relevant SEO stats if I had them. -->
      <!-- I will remove them to be safe and clean. -->
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg
      class="w-6 h-6 text-white"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
