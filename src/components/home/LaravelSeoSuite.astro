<section id="laravel-seo-suite" class="bg-slate-800 border-t border-slate-700 py-20" aria-labelledby="laravel-seo-suite-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
          Fully Automated SEO Suite
        </div>
        <h2 id="laravel-seo-suite-heading" class="text-3xl md:text-4xl font-bold text-white mb-6">
          Supercharge Your Laravel SEO With Real-Time Lighthouse Monitoring
        </h2>
        <p class="text-slate-300 text-lg mb-8">
          Take control of your site's search visibility with a fully automated optimisation suite built specifically for Laravel. Track, tune, and improve your SEO performance instantly — no guesswork, no external dashboards.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="https://app.laravelseo.com/contact" 
            class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-violet-600 hover:bg-violet-700 rounded-lg shadow-lg hover:shadow-violet-500/50 transition-all"
          >
            Request a Quote
          </a>
          <a 
            href="https://app.laravelseo.com/developers" 
            class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-violet-400 border border-violet-400 hover:bg-violet-400/10 rounded-lg transition-all"
          >
            Documentation
          </a>
        </div>
      </div>
      <div class="mt-8 lg:mt-0">
        <div class="relative">
          <div class="absolute inset-0 bg-violet-600 opacity-10 rounded-2xl transform rotate-3"></div>
          <div class="relative bg-slate-900/80 backdrop-blur rounded-2xl p-8 border border-slate-700/50 shadow-2xl">
            <div class="flex items-center mb-6">
              <div class="w-12 h-12 bg-violet-600/20 rounded-xl flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h4 class="text-white font-bold text-lg">Laravel SEO Dashboard</h4>
            </div>
            <div class="flex gap-2">
              <div class="w-1/4 bg-violet-600/30 rounded-lg" style="height: 160px;"></div>
              <div class="w-1/4 bg-violet-600/50 rounded-lg" style="height: 160px;"></div>
              <div class="w-1/4 bg-violet-600/20 rounded-lg" style="height: 160px;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>