---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
    title: "SEO",
    description: "Get an in-depth analysis on the most important tags and the content of your webpage."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Performance",
    description: "Improve the performance of your webpage's with key metrics and suggestions."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Security",
    description: "Obtain privacy and security information to keep your webpage's health in good standing."
  }
];

const checks = [
  { label: "Title", status: "success", message: "The title tag is perfect." },
  { label: "Meta description", status: "error", message: "The meta description tag is missing or empty." },
  { label: "Load time", status: "success", message: "The webpage loaded in 0.02 seconds." },
  { label: "Structured data", status: "warning", message: "There are no structured data tags on the webpage." },
  { label: "JavaScript defer", status: "neutral", message: "There are 10 javascript resources without the defer attribute." },
  { label: "Content length", status: "success", message: "The webpage has 2,995 words." }
];
---

<section class="bg-slate-800 py-16 md:py-28" aria-labelledby="advanced-reports-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Right Column - Features (order on desktop) -->
      <div class="order-2 lg:order-1 mt-8 lg:mt-0">
        <div class="bg-slate-900/50 rounded-2xl p-6 shadow-xl border border-slate-700/50">
          <div class="space-y-4">
            {checks.map(check => (
              <div class="flex items-center justify-between p-3 bg-slate-800/50 rounded-xl">
                <div class="flex items-center gap-3">
                  <div class={`w-4 h-4 rounded-full flex items-center justify-center ${
                    check.status === 'success' ? 'bg-green-500' : 
                    check.status === 'error' ? 'bg-red-500' : 
                    check.status === 'warning' ? 'bg-yellow-500' : 'bg-slate-500'
                  }`}>
                    {check.status === 'success' && (
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    )}
                    {check.status === 'error' && (
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                    )}
                    {check.status === 'warning' && (
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92A5.5 5.5 0 0017.5 19H3.5a5.5 5.5 0 00-4.743 6.099l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    )}
                  </div>
                  <div>
                    <div class="text-white font-medium">{check.label}</div>
                    <div class="text-slate-400 text-xs">{check.message}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Left Column - Text -->
      <div class="order-1 lg:order-2">
        <h2 id="advanced-reports-heading" class="text-2xl md:text-3xl font-bold text-white mb-4">
          Advanced reports
        </h2>
        <p class="text-slate-300 text-lg mb-8">
          Detailed reports that enables you to take actions on issues that actually matter.
        </p>

        <div class="space-y-6">
          {features.map(feature => (
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-violet-600/20 rounded-xl flex items-center justify-center flex-shrink-0 text-violet-400">
                <Fragment set:html={feature.icon} />
              </div>
              <div>
                <h5 class="text-white font-semibold mb-1">{feature.title}</h5>
                <p class="text-slate-400 text-sm">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>