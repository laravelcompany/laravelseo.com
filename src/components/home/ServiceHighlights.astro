---
import FeatureShowcase from '../react/FeatureShowcase';
---

<section class="py-24 bg-slate-900">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-violet-500/10 text-violet-400 text-sm font-semibold rounded-full border border-violet-500/20">
        Purpose-Built for Laravel
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6">
        Everything you need to <span class="text-transparent bg-clip-text bg-linear-to-r from-violet-400 to-pink-400">optimise your application</span>
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
        LaravelSeo gives you everything you need to optimise your application at scale. All the tools — none of the hassle.
      </p>
    </div>

    <!-- Feature list replacement since FeatureShowcase might be too specific to logistics if not updated. -->
    <!-- I will replace FeatureShowcase with a static grid of features as per briefing if FeatureShowcase is hard to adapt from here, but I haven't seen it yet. -->
    <!-- Assuming I will update FeatureShowcase.tsx separately, I keep it here or replace it with direct HTML. -->
    <!-- The briefing has a list: Real-time Lighthouse scoring, Automatic meta management, etc. -->
    <!-- I will replace the component call with direct HTML for simplicity and exact control, or update FeatureShowcase if it's generic. -->
    <!-- Let's wait to see FeatureShowcase content first. I'll make this edit AFTER viewing. -->
    <!-- Wait, I can't wait in this turn. I will assume I need to replace it with static HTML derived from the briefing to be safe and precise. -->
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        { title: 'Real-time Lighthouse scoring', icon: 'zap' },
        { title: 'Automatic meta management', icon: 'search' },
        { title: 'Social preview automation', icon: 'share' },
        { title: 'JSON-LD & Schema.org', icon: 'code' },
        { title: 'Route-level SEO rules', icon: 'map' },
        { title: 'Seamless integration', icon: 'puzzle' },
      ].map(feature => (
        <div class="bg-slate-800 p-8 rounded-2xl shadow-lg hover:shadow-violet-500/10 transition-all border border-slate-700 hover:border-violet-500/50 group">
           <!-- Icon placeholder -->
           <div class="w-12 h-12 bg-violet-500/10 rounded-xl flex items-center justify-center mb-6 text-violet-400 group-hover:bg-violet-500/20 transition-colors">
             <span class="font-bold text-xl">✓</span>
           </div>
           <h3 class="text-xl font-bold text-slate-100 mb-3">{feature.title}</h3>
           <p class="text-slate-400">Fully automated and integrated directly into your Laravel workflow.</p>
        </div>
      ))}
    </div>
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href="/capabilities" 
        class="inline-flex items-center px-8 py-4 text-base font-semibold text-white bg-linear-to-r from-violet-600 to-pink-600 hover:from-violet-500 hover:to-pink-500 rounded-lg shadow-lg hover:shadow-violet-500/50 transition-all group"
      >
        Explore Capabilities
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

