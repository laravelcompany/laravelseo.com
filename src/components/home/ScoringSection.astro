---
---

<section id="scoring" class="bg-slate-900 py-20" aria-labelledby="scoring-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left - Score Circle -->
      <div class="order-2 lg:order-1 mt-8 lg:mt-0 flex justify-center">
        <div class="relative text-center">
          <div class="w-32 h-32 rounded-full border-4 border-violet-500 flex items-center justify-center">
            <span class="text-5xl font-bold text-violet-400">100</span>
          </div>
          <div class="absolute -top-2 -right-2 bg-slate-800 px-4 py-1 rounded-full shadow-lg border border-slate-700">
            <span class="text-green-400 font-semibold">Perfect SEO Score</span>
          </div>
        </div>
      </div>

      <!-- Right - Content -->
      <div class="order-1 lg:order-2">
        <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
          Objective Scoring
        </div>
        <h2 id="scoring-heading" class="text-3xl md:text-4xl font-bold text-white mb-6">
          Why Google Lighthouse?
        </h2>
        <p class="text-slate-300 text-lg mb-6">
          It's Google's own scoring system — the most objective way to measure SEO quality, Core Web Vitals, accessibility, and performance. LaravelSeo integrates it directly into your project so you can iterate faster and deploy with confidence.
        </p>
        <a 
          href="https://app.laravelseo.com/developers" 
          class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-violet-400 border border-violet-400 hover:bg-violet-400/10 rounded-lg transition-all"
        >
          Learn more about Scoring
        </a>
      </div>
    </div>
  </div>
</section>