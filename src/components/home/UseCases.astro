---
const useCases = [
  { 
    title: "SaaS Product Teams", 
    description: "Building Laravel SaaS",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`
  },
  { 
    title: "Agencies", 
    description: "Maintaining multiple client sites",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`
  },
  { 
    title: "Senior Developers", 
    description: "Managing complex route structures",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`
  },
  { 
    title: "eCommerce Stores", 
    description: "With large catalogues",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`
  },
  { 
    title: "Marketing Teams", 
    description: "Who need instant SEO feedback",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>`
  }
];
---

<section id="use-cases" class="bg-slate-900 py-20" aria-labelledby="use-cases-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
        Target Audience
      </div>
      <h2 id="use-cases-heading" class="text-3xl md:text-4xl font-bold text-white mb-4">
        Who Uses LaravelSeo?
      </h2>
      <p class="text-slate-300 text-lg">
        If your business runs on Laravel, this is the SEO toolkit you've been waiting for.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {useCases.map(useCase => (
        <div class="p-6 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-violet-500/50 hover:shadow-lg hover:shadow-violet-500/10 transition-all hover:-translate-y-1 h-full">
          <div class="w-12 h-12 bg-violet-600/20 rounded-lg flex items-center justify-center mb-4 text-violet-400">
            <Fragment set:html={useCase.icon} />
          </div>
          <h4 class="text-white font-bold mb-2">{useCase.title}</h4>
          <p class="text-slate-400 mb-0">{useCase.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>