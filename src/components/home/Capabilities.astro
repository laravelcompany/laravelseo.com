---
const features = [
  { title: "Real-time Lighthouse scoring", description: "Fully automated and integrated directly into your Laravel workflow." },
  { title: "Automatic meta management", description: "Fully automated and integrated directly into your Laravel workflow." },
  { title: "Social preview automation", description: "Fully automated and integrated directly into your Laravel workflow." },
  { title: "JSON-LD & Schema.org", description: "Fully automated and integrated directly into your Laravel workflow." },
  { title: "Route-level SEO rules", description: "Fully automated and integrated directly into your Laravel workflow." },
  { title: "Seamless integration", description: "Fully automated and integrated directly into your Laravel workflow." }
];
---

<section id="capabilities" class="bg-slate-900 py-20" aria-labelledby="capabilities-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
        Purpose-Built for Laravel
      </div>
      <h2 id="capabilities-heading" class="text-3xl md:text-4xl font-bold text-white mb-4">
        Everything you need to optimise your application
      </h2>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">
        LaravelSeo gives you everything you need to optimise your application at scale. All the tools — none of the hassle.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {features.map(feature => (
        <div class="p-6 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-violet-500/50 hover:shadow-lg hover:shadow-violet-500/10 transition-all h-full">
          <div class="w-10 h-10 bg-green-500/20 rounded-full flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 15.9 11.79">
              <path d="M5.37,11.79a1.2,1.2,0,0,1-.33,0,1.24,1.24,0,0,1-.47-.24h0l0-.05h0L.37,7.3A1.25,1.25,0,0,1,2.13,5.53L5.37,8.77l8.4-8.4a1.25,1.25,0,0,1,1.77,1.76L6.25,11.42h0A1.24,1.24,0,0,1,5.37,11.79Z"/>
            </svg>
          </div>
          <h5 class="text-white font-bold mb-2">{feature.title}</h5>
          <p class="text-slate-400 text-sm mb-0">{feature.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a 
        href="/capabilities" 
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-violet-600 hover:bg-violet-700 rounded-lg shadow-lg hover:shadow-violet-500/50 transition-all"
      >
        Explore Capabilities
      </a>
    </div>
  </div>
</section>