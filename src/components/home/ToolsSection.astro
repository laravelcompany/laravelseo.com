---

<section class="bg-slate-900 py-16 md:py-24" aria-labelledby="tools-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="tools-heading" class="text-2xl md:text-3xl font-bold text-white mb-4">SEO Tools & Utilities</h2>
      <p class="text-slate-300 text-lg">30+ free web tools to audit and improve your website's SEO.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {tools.map(tool => (
        <a 
          href="#" 
          class="flex items-center gap-3 p-4 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-violet-500/50 hover:bg-slate-800 transition-all group"
        >
          <div class="w-10 h-10 bg-violet-600/20 rounded-lg flex items-center justify-center flex-shrink-0 text-violet-400 group-hover:text-violet-300 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tool.icon}/>
            </svg>
          </div>
          <span class="text-white font-medium text-sm">{tool.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>