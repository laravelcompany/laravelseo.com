---
---

<section id="get-started" class="bg-violet-600 text-white py-20 overflow-hidden relative" aria-labelledby="get-started-heading">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: linear-gradient(45deg, white 25%, transparent 25%), linear-gradient(-45deg, white 25%, transparent 25%), linear-gradient(45deg, transparent 75%, white 75%), linear-gradient(-45deg, transparent 75%, white 75%); background-size: 60px 60px; background-position: 0 0, 0 30px, 30px -30px, -30px 0px;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-block px-4 py-2 bg-white/20 text-white text-sm font-semibold rounded-full mb-4">
          Get Started Today
        </div>
        <h2 id="get-started-heading" class="text-3xl md:text-4xl font-bold mb-6">
          Ready to Optimize with LaravelSeo?
        </h2>
        <p class="text-white/80 text-lg mb-8">
          Take control of your site's search visibility today. Fully automated, deeply integrated, developer-friendly.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a 
            href="https://app.laravelseo.com/contact" 
            class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-violet-600 bg-white hover:bg-gray-100 rounded-lg shadow-lg transition-all"
          >
            Request a Quote
          </a>
          <a 
            href="https://app.laravelseo.com/developers" 
            class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white border border-white hover:bg-white/10 rounded-lg transition-all"
          >
            Documentation
          </a>
        </div>
      </div>
      <div class="mt-8 lg:mt-0">
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-white/10 rounded-lg border border-white/20">
            <div class="text-3xl font-bold mb-1">25+</div>
            <div class="text-sm opacity-80">Years Experience</div>
          </div>
          <div class="p-4 bg-white/10 rounded-lg border border-white/20">
            <div class="text-3xl font-bold mb-1">ISO</div>
            <div class="text-sm opacity-80">9001 Certified</div>
          </div>
          <div class="p-4 bg-white/10 rounded-lg border border-white/20">
            <div class="text-3xl font-bold mb-1">24/7</div>
            <div class="text-sm opacity-80">Support</div>
          </div>
          <div class="p-4 bg-white/10 rounded-lg border border-white/20">
            <div class="text-3xl font-bold mb-1">Global</div>
            <div class="text-sm opacity-80">Network</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>