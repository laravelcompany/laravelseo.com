---

<section class="bg-slate-950 py-16 md:py-24 border-t border-slate-800" aria-labelledby="package-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <div class="bg-slate-900/80 rounded-2xl p-8 border border-slate-800 shadow-2xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="flex items-center justify-center w-12 h-12 bg-violet-600/20 rounded-xl">
              <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <div>
              <h4 class="text-white font-bold text-lg">composer require laravelseo/core</h4>
              <p class="text-slate-400 text-sm">PHP Package</p>
            </div>
          </div>
          
          <div class="space-y-4">
            <div class="p-4 bg-slate-800/50 rounded-xl">
              <div class="flex items-center justify-between mb-2">
                <span class="text-white font-medium">Performance Score</span>
                <span class="text-green-400 font-bold">92/100</span>
              </div>
              <div class="w-full bg-slate-700 rounded-full h-2">
                <div class="bg-green-500 h-2 rounded-full" style="width: 92%"></div>
              </div>
            </div>
            
            <div class="p-4 bg-slate-800/50 rounded-xl">
              <div class="flex items-center justify-between mb-2">
                <span class="text-white font-medium">SEO Score</span>
                <span class="text-green-400 font-bold">88/100</span>
              </div>
              <div class="w-full bg-slate-700 rounded-full h-2">
                <div class="bg-green-500 h-2 rounded-full" style="width: 88%"></div>
              </div>
            </div>
            
            <div class="p-4 bg-slate-800/50 rounded-xl">
              <div class="flex items-center justify-between mb-2">
                <span class="text-white font-medium">Accessibility</span>
                <span class="text-yellow-400 font-bold">75/100</span>
              </div>
              <div class="w-full bg-slate-700 rounded-full h-2">
                <div class="bg-yellow-500 h-2 rounded-full" style="width: 75%"></div>
              </div>
            </div>
          </div>
          
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-violet-600/20 text-violet-400 text-xs rounded-full">Laravel 10</span>
            <span class="px-3 py-1 bg-violet-600/20 text-violet-400 text-xs rounded-full">Laravel 11</span>
            <span class="px-3 py-1 bg-violet-600/20 text-violet-400 text-xs rounded-full">PHP 8.2+</span>
            <span class="px-3 py-1 bg-violet-600/20 text-violet-400 text-xs rounded-full">Open Source</span>
          </div>
        </div>
      </div>
      
      <div class="order-1 lg:order-2">
        <div class="inline-block px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full mb-4">
          Open Source Package
        </div>
        <h2 id="package-heading" class="text-3xl md:text-4xl font-bold text-white mb-6">
          The Ultimate Laravel SEO Package
        </h2>
        <p class="text-slate-300 text-lg mb-6">
          Integrate professional-grade SEO auditing directly into your Laravel application. 
          The <code class="bg-slate-800 px-2 py-1 rounded text-violet-400">laravelseo/core</code> package provides 
          automated sitemap generation, meta tag optimization, structured data, and real-time Lighthouse audits.
        </p>
        
        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h4 class="text-white font-medium">Automatic Sitemap Generation</h4>
              <p class="text-slate-400 text-sm">Dynamic sitemaps that auto-update with your content</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h4 class="text-white font-medium">Schema.org Structured Data</h4>
              <p class="text-slate-400 text-sm">Automatic JSON-LD schemas for articles, products, and more</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h4 class="text-white font-medium">Lighthouse Integration</h4>
              <p class="text-slate-400 text-sm">Real-time performance and SEO auditing</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h4 class="text-white font-medium">SEO Score Monitoring</h4>
              <p class="text-slate-400 text-sm">Track and improve your SEO scores over time</p>
            </div>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="https://packagist.org/packages/laravelseo/core" 
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-violet-600 hover:bg-violet-700 rounded-lg shadow-lg hover:shadow-violet-500/50 transition-all"
          >
            Get Started
          </a>
          <a 
            href="https://app.laravelseo.com/developers" 
            class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-violet-400 border border-violet-400 hover:bg-violet-400/10 rounded-lg transition-all"
          >
            Documentation
          </a>
        </div>
      </div>
    </div>
  </div>
</section>