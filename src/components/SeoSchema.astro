---
import { SITE } from "@config/site";

const { schema = null, type = "website" } = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Laravel Seo",
  "url": "https://laravelseo.com",
  "logo": "https://laravelseo.com/logo.svg",
  "description": "Automated search visibility tools built specifically for Laravel applications.",
  "sameAs": [
    "https://twitter.com/laravelseo",
    "https://linkedin.com/company/laravelseo",
    "https://facebook.com/laravelseo"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "support@laravelseo.com",
    "contactType": "customer service"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Laravel Seo",
  "url": "https://laravelseo.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://laravelseo.com/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const schemas = schema ? [schema] : [organizationSchema, websiteSchema];
---

{schemas.map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
